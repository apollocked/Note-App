<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.NoteApp" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="android:statusBarColor">@color/primary_blue</item>
        <item name="actionBarStyle">@style/Widget.App.ActionBar</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Widget.App.ActionBar" parent="Widget.Material3.ActionBar.Solid">
        <item name="background">@color/primary_blue</item>
        <item name="titleTextStyle">@style/TextAppearance.App.ActionBarTitle</item>
    </style>

    <style name="TextAppearance.App.ActionBarTitle" parent="TextAppearance.Material3.ActionBar.Title">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="ShapeAppearance.App.FAB.Circle" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.NoteApp" parent="Base.Theme.NoteApp" />
</resources>